---
import Base from '../layouts/Base.astro';
---

<Base title="Module Control in Youth Symptom Networks — Companion Site">
  <main class="container">
    <h1>Site scaffold works</h1>
    <p>Design system loaded with domain colors.</p>
    <div style="display: flex; gap: 8px; margin-top: 16px;">
      <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--str);" title="STR"></div>
      <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--emo);" title="EMO"></div>
      <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--csf);" title="CSF"></div>
      <div style="width: 48px; height: 48px; border-radius: 8px; background: var(--spf);" title="SPF"></div>
    </div>
  </main>
</Base>
