      ph.edges.forEach(function(e){var a=domainCfg[e[0]],b=domainCfg[e[1]],w=e[2];if(!a||!b)return;var path=document.createElementNS(ns,'path'),mx=(a.x+b.x)/2,my=(a.y+b.y)/2,dx=b.x-a.x,dy=b.y-a.y,norm=Math.hypot(dx,dy)||1,cx=mx-(dy/norm)*36,cy=my+(dx/norm)*36;path.setAttribute('d','M '+a.x+' '+a.y+' Q '+cx+' '+cy+' '+b.x+' '+b.y);path.setAttribute('fill','none');path.setAttribute('stroke','rgba(232,237,242,0.25)');path.setAttribute('stroke-width',String(1.5+5.5*w));path.setAttribute('stroke-linecap','round');path.setAttribute('opacity',String(0.25+0.65*w));path.setAttribute('marker-end','url(#ah)');svg.appendChild(path);});
      var nodes=ph.extra?ph.nodes.concat([ph.extra]):ph.nodes.slice();
      nodes.forEach(function(key){var n=domainCfg[key];if(!n)return;var r=key==='PHY'?18:24;var halo=document.createElementNS(ns,'circle');halo.setAttribute('cx',String(n.x));halo.setAttribute('cy',String(n.y));halo.setAttribute('r',String(r+12));halo.setAttribute('fill',n.color);halo.setAttribute('opacity','0.15');svg.appendChild(halo);var circle=document.createElementNS(ns,'circle');circle.setAttribute('cx',String(n.x));circle.setAttribute('cy',String(n.y));circle.setAttribute('r',String(r));circle.setAttribute('fill',n.color);circle.setAttribute('stroke','#162236');circle.setAttribute('stroke-width','2.5');svg.appendChild(circle);var label=document.createElementNS(ns,'text');label.setAttribute('x',String(n.x));label.setAttribute('y',String(n.y+4.5));label.setAttribute('font-size',key==='PHY'?'10':'12');label.setAttribute('font-weight','500');label.setAttribute('font-family','IBM Plex Sans, sans-serif');label.setAttribute('text-anchor','middle');label.setAttribute('fill','white');label.textContent=key;svg.appendChild(label);});
      var pl=document.createElementNS(ns,'text');pl.setAttribute('x','20');pl.setAttribute('y','28');pl.setAttribute('font-size','12');pl.setAttribute('font-weight','500');pl.setAttribute('font-family','IBM Plex Sans, sans-serif');pl.setAttribute('fill','#E8EDF2');pl.textContent=ph.label+' phase';svg.appendChild(pl);
      var rl=document.createElementNS(ns,'text');rl.setAttribute('x','20');rl.setAttribute('y','44');rl.setAttribute('font-size','10');rl.setAttribute('font-family','IBM Plex Sans, sans-serif');rl.setAttribute('fill','#4A6080');rl.textContent=ph.regime;svg.appendChild(rl);
    }
    setPhase(0);
  })();

  // Backbone
  (function(){
    var pills=document.getElementById('bbPills'),detail=document.getElementById('bbDetail');
    symptoms.forEach(function(s,i){var btn=document.createElement('button');btn.className='bb-pill'+(i===0?' active':'');btn.textContent=s.name;btn.addEventListener('click',function(){setSymptom(i);});pills.appendChild(btn);});
    function setSymptom(idx){
      var s=symptoms[idx];pills.querySelectorAll('.bb-pill').forEach(function(b,i){b.classList.toggle('active',i===idx);});detail.textContent='';
      var tags=document.createElement('div');tags.style.marginBottom='12px';
      [s.domain,s.role].forEach(function(t){var sp=document.createElement('span');sp.className='bb-tag';sp.textContent=t;tags.appendChild(sp);});detail.appendChild(tags);
      var h=document.createElement('h4');h.textContent=s.name;detail.appendChild(h);
      var p1=document.createElement('p');var b1=document.createElement('strong');b1.textContent='Why: ';p1.appendChild(b1);p1.appendChild(document.createTextNode(s.why));detail.appendChild(p1);
      var p2=document.createElement('p');var b2=document.createElement('strong');b2.textContent='Interpretation: ';p2.appendChild(b2);p2.appendChild(document.createTextNode(s.use));detail.appendChild(p2);
    }
    setSymptom(0);
  })();

  // Accordion
  document.querySelectorAll('.accord-trigger').forEach(function(t){t.addEventListener('click',function(){var item=t.closest('.accord-item'),open=item.classList.contains('open');document.querySelectorAll('.accord-item').forEach(function(a){a.classList.remove('open');});if(!open)item.classList.add('open');});});
</script>
</body>
</html>
