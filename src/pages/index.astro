<script is:inline define:vars={{ phaseMetaList, phaseModuleGraphs, backboneNodesForView }}>
  var phases = phaseMetaList;
  var phaseGraphs = phaseModuleGraphs;
  var backboneNodes = backboneNodesForView;
  var phaseGraphMap = {};
  phaseGraphs.forEach(function(g){phaseGraphMap[g.phaseId]=g;});
  var moduleColors={STR:'#CC79A7',EMO:'#E69F00',CSF:'#56B4E9',SPF:'#009E73',PHY:'#D55E00'};

  // Counter
  function animateCounter(el,target,dur){dur=dur||1800;var start=null,fmt=target>999;function step(ts){if(!start)start=ts;var p=Math.min((ts-start)/dur,1),e=1-Math.pow(1-p,3),v=Math.floor(e*target);el.textContent=fmt?v.toLocaleString():v;if(p<1)requestAnimationFrame(step);else el.textContent=fmt?target.toLocaleString():target;}requestAnimationFrame(step);}

  // Observers
  var revealObs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.reveal,.stagger').forEach(function(el){revealObs.observe(el);});
  var counterDone=false;
  new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting&&!counterDone){counterDone=true;document.querySelectorAll('.h-stat-num').forEach(function(el){animateCounter(el,parseInt(el.dataset.target,10));});}});},{threshold:0.3}).observe(document.querySelector('.hero-stats'));
  // Nav active
  document.querySelectorAll('section[id]').forEach(function(s){new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)document.querySelectorAll('.nav-link').forEach(function(l){l.classList.toggle('active',l.getAttribute('href')==='#'+e.target.id);});});},{rootMargin:'-40% 0px -55% 0px'}).observe(s);});

  // Phase Explorer
  (function(){
    var tl=document.getElementById('timeline'),svg=document.getElementById('networkSvg'),ns='http://www.w3.org/2000/svg';
    var detailEl=document.getElementById('moduleDetail');
    var selectedEl=document.getElementById('selectedModule');
    var tip=document.getElementById('phaseTip');
    var activePhaseKey='early';
    var selectedModuleId=null;
    var phaseNodePositions={};
    var dragState=null;

    function showTip(e,text){
      if(!tip)return;
      tip.textContent=text;
      tip.classList.add('visible');
      tip.style.left=(e.clientX+14)+'px';
      tip.style.top=(e.clientY+14)+'px';
    }

    function moveTip(e){
      if(!tip||!tip.classList.contains('visible'))return;
      tip.style.left=(e.clientX+14)+'px';
      tip.style.top=(e.clientY+14)+'px';
    }

    function hideTip(){
      if(!tip)return;
      tip.classList.remove('visible');
    }

    function renderModuleDetail(phaseKey,moduleId){
      if(!detailEl)return;
      var graph=phaseGraphMap[phaseKey];
      if(!graph||!moduleId){
        detailEl.innerHTML='<p class="module-empty">Click a module node in the graph to view node details.</p>';
        if(selectedEl)selectedEl.innerHTML='Selected module: <strong>None</strong>';
        return;
      }
      var mod=graph.modules.find(function(m){return m.id===moduleId;});
      if(!mod){
        detailEl.innerHTML='<p class="module-empty">Module details unavailable for this phase.</p>';
        if(selectedEl)selectedEl.innerHTML='Selected module: <strong>None</strong>';
        return;
      }
      if(selectedEl)selectedEl.innerHTML='Selected module: <strong>'+mod.label+'</strong>';
      function englishOnly(name){
        return String(name||'').replace(/\s*\([^)]*[\u4e00-\u9fff][^)]*\)\s*$/,'').trim();
      }
      var nodesHtml=(mod.nodes&&mod.nodes.length)
        ? mod.nodes.map(function(n){return '<span class="module-node-pill">'+englishOnly(n)+'</span>';}).join('')
        : '<p class="module-empty">No node list found in module report.</p>';
      detailEl.innerHTML=
        '<h4>'+mod.label+' Module</h4>'+
        '<div class="module-meta">Node count: '+mod.nodeCount+'</div>'+
        '<div class="module-node-list">'+nodesHtml+'</div>';
    }

    function arcPath(a,b){
      var mx=(a.x+b.x)/2,my=(a.y+b.y)/2;
      var dx=b.x-a.x,dy=b.y-a.y;
      var norm=Math.hypot(dx,dy)||1;
      var curve=26;
      var cx=mx-(dy/norm)*curve;
      var cy=my+(dx/norm)*curve;
      return 'M '+a.x+' '+a.y+' Q '+cx+' '+cy+' '+b.x+' '+b.y;
    }

    function clamp(v,min,max){
      return Math.max(min,Math.min(max,v));
    }

    function toSvgCoord(evt){
      var rect=svg.getBoundingClientRect();
      var x=(evt.clientX-rect.left)*(480/rect.width);
      var y=(evt.clientY-rect.top)*(360/rect.height);
      return {x:clamp(x,56,424),y:clamp(y,56,320)};
    }

    phases.forEach(function(ph,i){
      var node=document.createElement('button');node.className='tl-node'+(i===0?' active':'');node.textContent=(i+1);
      var lbl=document.createElement('span');lbl.className='tl-label';lbl.textContent=ph.label;
      var dt=document.createElement('span');dt.className='tl-date';dt.textContent=ph.date;
      node.appendChild(lbl);node.appendChild(dt);
      node.addEventListener('click',function(){setPhase(i);});tl.appendChild(node);
    });

    function updatePhaseFigure(figId,imgId,capId,src,alt,caption){
      var fig=document.getElementById(figId);
      var img=document.getElementById(imgId);
      var cap=document.getElementById(capId);
      if(!fig||!img||!cap){return;}
      fig.classList.add('fading');
      img.src=src;
      img.alt=alt;
      cap.textContent=caption;
      setTimeout(function(){fig.classList.remove('fading');},280);
    }

    function setPhase(idx){
      var ph=phases[idx];
      activePhaseKey=ph.key;
      selectedModuleId=null;
      tl.querySelectorAll('.tl-node').forEach(function(n,i){n.classList.toggle('active',i===idx);});
      document.getElementById('pRegime').textContent=ph.regime;
      document.getElementById('pHeadline').textContent=ph.summary;
      document.getElementById('pContext').textContent=ph.context;
      document.getElementById('pStable').textContent=ph.stable;
      document.getElementById('pChange').textContent=ph.change;
      var badges=document.getElementById('pBadges');badges.textContent='';
      var graph=phaseGraphMap[ph.key];
      var moduleCount=(graph&&graph.moduleCount)?graph.moduleCount:0;
      [['n = ',ph.sample.toLocaleString()],['Modules: ',String(moduleCount)]].forEach(function(b){var sp=document.createElement('span');sp.className='p-badge';sp.textContent=b[0];var st=document.createElement('strong');st.textContent=b[1];sp.appendChild(st);badges.appendChild(sp);});
      renderModuleDetail(ph.key,null);
      updatePhaseFigure('phaseNetworkFig','phaseNetworkImg','phaseNetworkCap',ph.networkFigure,ph.label+' phase network figure',ph.networkCaption);
      updatePhaseFigure('phaseChordFig','phaseChordImg','phaseChordCap',ph.chordFigure,ph.label+' phase module chord diagram',ph.chordCaption);
      renderNetwork(ph,graph);
    }

    function renderNetwork(ph,graph){
      while(svg.firstChild)svg.removeChild(svg.firstChild);
      hideTip();
      if(!graph){
        return;
      }

      var width=480,height=360,cx=240,cy=186,radius=128;
      var defs=document.createElementNS(ns,'defs'),marker=document.createElementNS(ns,'marker');
      marker.setAttribute('id','ah');marker.setAttribute('markerWidth','10');marker.setAttribute('markerHeight','8');marker.setAttribute('refX','9');marker.setAttribute('refY','4');marker.setAttribute('orient','auto');
      var poly=document.createElementNS(ns,'polygon');poly.setAttribute('points','0 0, 10 4, 0 8');poly.setAttribute('fill','#64748b');
      marker.appendChild(poly);defs.appendChild(marker);svg.appendChild(defs);
      var bg=document.createElementNS(ns,'rect');bg.setAttribute('width',String(width));bg.setAttribute('height',String(height));bg.setAttribute('rx','10');bg.setAttribute('fill','#f7fbff');svg.appendChild(bg);
      var ring=document.createElementNS(ns,'circle');ring.setAttribute('cx',String(cx));ring.setAttribute('cy',String(cy));ring.setAttribute('r',String(radius));ring.setAttribute('fill','none');ring.setAttribute('stroke','#d8e4f5');ring.setAttribute('stroke-dasharray','4 6');svg.appendChild(ring);

      var modules=graph.modules||[];
      var preset={
        STR:{x:240,y:72},
        EMO:{x:392,y:176},
        CSF:{x:240,y:292},
        SPF:{x:88,y:176},
        PHY:{x:338,y:104}
      };
      var positions=phaseNodePositions[ph.key];
      if(!positions) positions={};
      var fallbackMods=modules.filter(function(mod){return !preset[mod.id];});
      var angleStep=(Math.PI*2)/Math.max(fallbackMods.length,1);
      var offset=0.28;
      modules.forEach(function(mod,i){
        if(positions[mod.id]){
          positions[mod.id].mod=mod;
        }else if(preset[mod.id]){
          positions[mod.id]={x:preset[mod.id].x,y:preset[mod.id].y,mod:mod};
        } else {
          var j=fallbackMods.findIndex(function(m){return m.id===mod.id;});
          var angle=(-Math.PI/2)+offset+(j*angleStep);
          positions[mod.id]={x:cx+Math.cos(angle)*radius,y:cy+Math.sin(angle)*radius,mod:mod};
        }
      });
      Object.keys(positions).forEach(function(k){ if(!modules.some(function(m){return m.id===k;})){ delete positions[k]; }});
      phaseNodePositions[ph.key]=positions;

      var validEdges=(graph.edges||[])
        .filter(function(e){return e.source!==e.target&&positions[e.source]&&positions[e.target];})
        .sort(function(a,b){return b.weight-a.weight;})
        .slice(0,Math.max((modules.length||0)+1,1));
      var maxW=0,minW=Infinity;
      validEdges.forEach(function(e){if(e.weight>maxW)maxW=e.weight;if(e.weight<minW)minW=e.weight;});
      if(!Number.isFinite(minW)){minW=0;maxW=1;}
      function strokeWidth(w){
        if(maxW===minW)return 3.8;
        var t=(w-minW)/(maxW-minW);
        return 2.8+(Math.sqrt(Math.max(0,t))*2.6);
      }

      validEdges.forEach(function(e){
        var a=positions[e.source],b=positions[e.target];
        var path=document.createElementNS(ns,'path');
        path.setAttribute('d',arcPath(a,b));
        path.setAttribute('fill','none');
        path.setAttribute('stroke','#8aa1bf');
        path.setAttribute('stroke-width',String(strokeWidth(e.weight)));
        path.setAttribute('stroke-linecap','round');
        path.setAttribute('opacity','0.82');
        path.setAttribute('marker-end','url(#ah)');
        path.addEventListener('mouseenter',function(evt){showTip(evt,e.source+' → '+e.target+' | AMCS: '+e.weight.toFixed(3));});
        path.addEventListener('mousemove',moveTip);
        path.addEventListener('mouseleave',hideTip);
        svg.appendChild(path);

        var tx=(a.x*0.45+b.x*0.55),ty=(a.y*0.45+b.y*0.55);
        var val=document.createElementNS(ns,'text');
        val.setAttribute('x',String(tx));
        val.setAttribute('y',String(ty-6));
        val.setAttribute('font-size','12');
        val.setAttribute('font-weight','600');
        val.setAttribute('font-family','IBM Plex Sans, sans-serif');
        val.setAttribute('text-anchor','middle');
        val.setAttribute('fill','#334155');
        val.textContent=e.weight.toFixed(2);
        svg.appendChild(val);
      });

      modules.forEach(function(mod){
        var p=positions[mod.id];
        var color=moduleColors[mod.id]||'#1d4ed8';
        var r=22;
        var halo=document.createElementNS(ns,'circle');halo.setAttribute('cx',String(p.x));halo.setAttribute('cy',String(p.y));halo.setAttribute('r',String(r+9));halo.setAttribute('fill',color);halo.setAttribute('opacity','0.16');halo.style.pointerEvents='none';svg.appendChild(halo);
        var circle=document.createElementNS(ns,'circle');circle.setAttribute('cx',String(p.x));circle.setAttribute('cy',String(p.y));circle.setAttribute('r',String(r));circle.setAttribute('fill',color);circle.setAttribute('stroke','#ffffff');circle.setAttribute('stroke-width','2.5');circle.style.cursor='grab';
        circle.addEventListener('mouseenter',function(evt){showTip(evt,mod.label+' | nodes: '+(mod.nodeCount||mod.nodes.length||0));});
        circle.addEventListener('mousemove',moveTip);
        circle.addEventListener('mouseleave',hideTip);
        circle.addEventListener('mousedown',function(evt){
          evt.preventDefault();
          var point=toSvgCoord(evt);
          dragState={phaseKey:ph.key,moduleId:mod.id,ph:ph,graph:graph,offsetX:positions[mod.id].x-point.x,offsetY:positions[mod.id].y-point.y,moved:false};
          circle.style.cursor='grabbing';
        });
        circle.addEventListener('click',function(){
          if(dragState&&dragState.moved){return;}
          selectedModuleId=mod.id;
          renderModuleDetail(activePhaseKey,selectedModuleId);
          renderNetwork(ph,graph);
        });
        svg.appendChild(circle);
        if(selectedModuleId===mod.id){
          var sel=document.createElementNS(ns,'circle');
          sel.setAttribute('cx',String(p.x));sel.setAttribute('cy',String(p.y));sel.setAttribute('r',String(r+14));
          sel.setAttribute('fill','none');sel.setAttribute('stroke','#1d4ed8');sel.setAttribute('stroke-width','2');
          sel.style.pointerEvents='none';
          svg.appendChild(sel);
        }
        var label=document.createElementNS(ns,'text');label.setAttribute('x',String(p.x));label.setAttribute('y',String(p.y+4));label.setAttribute('font-size',mod.label.length>3?'10':'12');label.setAttribute('font-weight','600');label.setAttribute('font-family','IBM Plex Sans, sans-serif');label.setAttribute('text-anchor','middle');label.setAttribute('fill','#ffffff');label.style.pointerEvents='none';label.textContent=mod.label;svg.appendChild(label);
      });

      var pl=document.createElementNS(ns,'text');pl.setAttribute('x','20');pl.setAttribute('y','28');pl.setAttribute('font-size','12');pl.setAttribute('font-weight','600');pl.setAttribute('font-family','IBM Plex Sans, sans-serif');pl.setAttribute('fill','#0f172a');pl.textContent=ph.label+' phase';svg.appendChild(pl);
      var rl=document.createElementNS(ns,'text');rl.setAttribute('x','20');rl.setAttribute('y','44');rl.setAttribute('font-size','10');rl.setAttribute('font-family','IBM Plex Sans, sans-serif');rl.setAttribute('fill','#64748b');rl.textContent=ph.regime;svg.appendChild(rl);
      var hint=document.createElementNS(ns,'text');hint.setAttribute('x','20');hint.setAttribute('y','344');hint.setAttribute('font-size','10');hint.setAttribute('font-family','IBM Plex Sans, sans-serif');hint.setAttribute('fill','#94a3b8');hint.textContent='Tip: drag nodes to improve readability';svg.appendChild(hint);
    }

    window.addEventListener('mousemove',function(evt){
      if(!dragState){return;}
      var graph=phaseGraphMap[dragState.phaseKey];
      if(!graph){return;}
      var point=toSvgCoord(evt);
      var nextX=clamp(point.x+dragState.offsetX,56,424);
      var nextY=clamp(point.y+dragState.offsetY,56,320);
      var pos=phaseNodePositions[dragState.phaseKey];
      if(!pos||!pos[dragState.moduleId]){return;}
      pos[dragState.moduleId].x=nextX;
      pos[dragState.moduleId].y=nextY;
      dragState.moved=true;
      renderNetwork(dragState.ph,graph);
    });

    window.addEventListener('mouseup',function(){
      if(!dragState){return;}
      setTimeout(function(){ dragState=null; },0);
    });

    setPhase(0);
  })();

  // Backbone detail card sync (left list -> right text card)
  (function(){
    var detail=document.getElementById('bbDetail');
    var buttons=Array.prototype.slice.call(document.querySelectorAll('.bb-node-btn'));
    if(!detail||!buttons.length||!Array.isArray(backboneNodes)){return;}

    var domainLabel={STR:'Stress',EMO:'Emotion',CSF:'Cognitive-social',SPF:'Self/physiology',PHY:'Physiological'};
    var nodeMap={};
    backboneNodes.forEach(function(n){nodeMap[String(n.id)]=n;});

    function fmt(v){
      return (typeof v==='number'&&Number.isFinite(v)) ? v.toFixed(6) : 'N/A';
    }

    function esc(s){
      return String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
    }

    function renderNode(node){
      if(!node){return;}
      var domainName=domainLabel[node.domain]||node.domain||'Unknown';
      detail.innerHTML=
        '<span class="bb-tag">Backbone set</span>'+
        '<span class="bb-tag">Node interpretation</span>'+
        '<h4>#'+esc(node.id)+' '+esc(node.name)+'</h4>'+
        '<p class="bb-metrics">Domain: '+esc(node.domain)+' ('+esc(domainName)+') · avg CF: '+fmt(node.avgCF)+' · CV: '+fmt(node.cv)+'</p>'+
        '<p><strong>Why:</strong> '+esc(node.why||'Included in the manuscript backbone set for cross-phase interpretation.')+'</p>'+
        '<p><strong>Interpretation:</strong> '+esc(node.interpretation||'Used as a stable reference node under the conserved module scaffold.')+'</p>';
    }

    function setActiveNode(id){
      buttons.forEach(function(btn){
        btn.classList.toggle('active',btn.getAttribute('data-bb-node')===String(id));
      });
      renderNode(nodeMap[String(id)]);
    }

    buttons.forEach(function(btn){
      btn.addEventListener('click',function(){
        var id=btn.getAttribute('data-bb-node');
        if(!id){return;}
        setActiveNode(id);
      });
    });

    var defaultBtn=buttons.find(function(btn){return btn.classList.contains('active');}) || buttons[0];
    var defaultId=defaultBtn&&defaultBtn.getAttribute('data-bb-node');
    if(defaultId){setActiveNode(defaultId);}
  })();

  // Accordion
  document.querySelectorAll('.accord-trigger').forEach(function(t){t.addEventListener('click',function(){var item=t.closest('.accord-item'),open=item.classList.contains('open');document.querySelectorAll('.accord-item').forEach(function(a){a.classList.remove('open');});if(!open)item.classList.add('open');});});
</script>
</body>
</html>
