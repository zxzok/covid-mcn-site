    .gl-entry dt .tag { font-size: 0.64rem; font-weight: 500; color: var(--muted); background: rgba(74,96,128,0.2); padding: 2px 7px; border-radius: 4px; margin-left: 6px; vertical-align: middle; }
    .gl-entry dd { font-size: 0.84rem; color: var(--muted); line-height: 1.55; }
    .res-btn { display: flex; align-items: center; gap: 12px; padding: 16px 24px; border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); text-decoration: none; font-size: 0.9rem; flex: 1; min-width: 180px; transition: all 0.25s; }
    .res-btn:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); text-decoration: none; }
    .res-btn-icon { width: 36px; height: 36px; border-radius: 8px; background: rgba(29,78,216,0.1); display: grid; place-items: center; font-size: 0.7rem; font-weight: 500; color: var(--accent); flex-shrink: 0; }
    .phase-tip { position: fixed; z-index: 200; background: #0f172a; color: #fff; border-radius: 8px; padding: 6px 8px; font-size: 0.72rem; line-height: 1.35; pointer-events: none; opacity: 0; transform: translateY(4px); transition: opacity 0.12s ease, transform 0.12s ease; }
    .phase-tip.visible { opacity: 1; transform: translateY(0); }
    .module-detail { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
    .module-detail h4 { font-size: 1rem; margin-bottom: 6px; }
    .module-meta { font-size: 0.82rem; color: var(--muted); margin-bottom: 12px; }
    .module-empty { font-size: 0.84rem; color: var(--muted); }
    .module-node-list { max-height: 190px; overflow: auto; display: flex; flex-wrap: wrap; gap: 8px; padding-right: 4px; }
    .module-node-pill { border: 1px solid var(--border); border-radius: 999px; padding: 4px 10px; font-size: 0.76rem; background: #f8fbff; color: var(--text); }
    .res-btn-text span { display: block; font-size: 0.84rem; color: var(--muted); }
    .citation { font-size: 0.84rem; color: var(--muted); line-height: 1.6; border-top: 1px solid var(--border); padding-top: 24px; max-width: 60ch; font-family: 'IBM Plex Sans', monospace; }

    /* ── Scroll reveal ── */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .stagger > * { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .stagger.visible > *:nth-child(1) { transition-delay: 0s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(2) { transition-delay: 0.08s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(3) { transition-delay: 0.12s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(4) { transition-delay: 0.18s; opacity: 1; transform: none; }
    .stagger.visible > *:nth-child(5) { transition-delay: 0.24s; opacity: 1; transform: none; }

    /* ── Utility ── */
    .mt16 { margin-top: 16px; } .mt24 { margin-top: 24px; } .mt36 { margin-top: 36px; }
    .gap8 { gap: 8px; } .gap12 { gap: 12px; } .gap16 { gap: 16px; }
    .flex-col { display: flex; flex-direction: column; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { min-height: 82vh; padding-top: 64px; }
      .hero-ctas { gap: 8px; }
      .hero-cta { width: 100%; max-width: 320px; }
      .hero-stats { gap: 20px; flex-wrap: wrap; justify-content: center; }
      .g2, .g12 { grid-template-columns: 1fr; }
      .g3 { grid-template-columns: 1fr; }
      .timeline { overflow-x: auto; justify-content: flex-start; padding-bottom: 32px; -webkit-overflow-scrolling: touch; }
      .timeline::before { display: none; }
      .tl-node { flex-shrink: 0; margin: 0 16px; }
      .wrap { width: calc(100vw - 32px); }
      .methods-figure-shell { width: calc(100vw - 32px); }
      .pipeline-horizontal { min-width: 980px; }
      .rob-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>
