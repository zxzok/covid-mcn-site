---
import fs from 'node:fs';
import path from 'node:path';

type ModuleEntry = {
  id: string;
  label: string;
  nodeCount: number;
  nodes: string[];
};

type PhaseGraph = {
  phaseId: string;
  moduleCount: number;
  modules: ModuleEntry[];
  edges: { source: string; target: string; weight: number }[];
};

const phaseOrder = ['early', 'first', 'second', 'omicron', 'post'] as const;
const normalizedBaseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const phaseMeta: Record<string, { key: string; label: string; date: string; sample: number; regime: string; context: string; summary: string; stable: string; change: string; networkFigure: string; chordFigure: string; networkCaption: string; chordCaption: string }> = {
  early: { key: 'early', label: 'Early', date: '2020.04–07', sample: 518, regime: 'Stress-centered', context: 'Abrupt restriction, uncertainty, school disruption, and acute threat appraisal.', summary: 'Stress-related circuitry dominates outgoing control, shaping downstream emotional and cognitive-social modules.', stable: 'The broad modular scaffold remains recognizable, organized into coherent symptom communities.', change: 'Stress has the clearest control advantage — the cleanest "acute-response regime" phase.', networkFigure: `${normalizedBaseUrl}figs/earlyphase_network.svg`, chordFigure: `${normalizedBaseUrl}figs/earlyphase_chord.svg`, networkCaption: 'Early phase network figure', chordCaption: 'Early phase module chord diagram' },
  first: { key: 'first', label: 'First Wave', date: '2020.07–2021.01', sample: 2321, regime: 'Stress + physiological', context: 'Sustained disruption with stress still the main organizing force.', summary: 'Stress remains the leading controller. A physiological subcluster becomes visible without changing four-domain interpretation.', stable: 'Core architecture persists, reinforcing that phase-wise comparison is meaningful on a conserved scaffold.', change: 'Even when communities split visually, the higher-order interpretation remains stable.', networkFigure: `${normalizedBaseUrl}figs/firstwave_network.svg`, chordFigure: `${normalizedBaseUrl}figs/firstwave_chord.svg`, networkCaption: 'First Wave network figure', chordCaption: 'First Wave module chord diagram' },
  second: { key: 'second', label: 'Second Wave', date: '2021.01–2022.01', sample: 4721, regime: 'Beginning redistribution', context: 'The crisis is no longer only acute; control becomes less monopolized by stress.', summary: 'Network scaffold intact, but the control map begins to distribute more visibly across multiple domains.', stable: 'Community organization broadly similar, preserving the central scaffold claim.', change: 'The transition phase — shift from dominance to broader governance begins to emerge.', networkFigure: `${normalizedBaseUrl}figs/secondwave_network.svg`, chordFigure: `${normalizedBaseUrl}figs/secondwave_chord.svg`, networkCaption: 'Second Wave network figure', chordCaption: 'Second Wave module chord diagram' },
  omicron: { key: 'omicron', label: 'Omicron', date: '2022.01–2023.01', sample: 4023, regime: 'Distributed cross-domain', context: 'System reflects chronic adaptation rather than only acute stress response.', summary: 'Control more evenly shared across stress, cognitive-social, and self-perception/physiological domains.', stable: 'Architecture does not collapse or fragment into a qualitatively different system.', change: 'Supports the move toward multi-module governance under prolonged crisis.', networkFigure: `${normalizedBaseUrl}figs/omicron_network.svg`, chordFigure: `${normalizedBaseUrl}figs/omicron_chord.svg`, networkCaption: 'Omicron phase network figure', chordCaption: 'Omicron phase module chord diagram' },
  post: { key: 'post', label: 'Post-Omicron', date: '2023.01–2024.01', sample: 2598, regime: 'Broad multi-module', context: 'Restrictions ease, but accumulated burden and adaptation continue to shape interaction.', summary: 'Greater boundary mixing with broader, more distributed control beyond early stress dominance.', stable: 'Persistent backbone of influential symptoms supports continuity across the full window.', change: 'Clearest phase for chronic adaptation, boundary mixing, and integrative leverage.', networkFigure: `${normalizedBaseUrl}figs/postomicron_network.svg`, chordFigure: `${normalizedBaseUrl}figs/postomicron_chord.svg`, networkCaption: 'Post-Omicron network figure', chordCaption: 'Post-Omicron module chord diagram' }
};

function phaseIdFromText(input: string): string | null {
  const t = input.trim();
  const low = t.toLowerCase();
  if (low.includes('post omicron') || t.includes('Omicron后') || t.includes('后阶段')) return 'post';
  if (low.includes('early phase') || t.includes('早期')) return 'early';
  if (low.includes('first wave') || t.includes('第一波')) return 'first';
  if (low.includes('second wave') || t.includes('第二波')) return 'second';
  if (low.includes('omicron')) return 'omicron';
  return null;
}

function parseModuleReport(reportText: string): Record<string, ModuleEntry[]> {
  const lines = reportText.split(/\r?\n/);
  const parsed: Record<string, ModuleEntry[]> = {};
  let currentPhase: string | null = null;
  let currentModule: ModuleEntry | null = null;

  for (const line of lines) {
    const sectionMatch = line.match(/^##\s+(.+)$/);
    if (sectionMatch) {
      currentPhase = phaseIdFromText(sectionMatch[1]);
      currentModule = null;
      if (currentPhase && !parsed[currentPhase]) parsed[currentPhase] = [];
      continue;
    }

    if (!currentPhase) continue;

    const moduleMatch = line.match(/^###\s*模块\d+\s*-\s*(.+?)\s*-\s*([A-Z]{3})\s*$/);
    if (moduleMatch) {
      currentModule = { id: moduleMatch[2], label: moduleMatch[2], nodeCount: 0, nodes: [] };
      parsed[currentPhase].push(currentModule);
      continue;
    }

    if (!currentModule) continue;

    const countMatch = line.match(/节点数量:\s*(\d+)/);
    if (countMatch) {
      currentModule.nodeCount = Number(countMatch[1]);
      continue;
    }

    const nodeMatch = line.match(/^\s*-\s+(.+)$/);
    if (nodeMatch) currentModule.nodes.push(nodeMatch[1].trim());
  }

  return parsed;
}

function parsePhaseCsv(csvText: string) {
  const rows = csvText.split(/\r?\n/).filter(Boolean);
  return rows.slice(1).map((line) => {
    const [source, target, weightRaw] = line.split(',');
    return { source: source.trim(), target: target.trim(), weight: Number(weightRaw) };
  }).filter((r) => r.source && r.target && Number.isFinite(r.weight));
}

type BackboneMetric = {
  domain: string;
  avgCF: number;
  cv: number;
  role: string;
};

function parseBackboneMetricCsv(csvText: string): Record<number, BackboneMetric> {
  const rows = csvText.split(/\r?\n/).filter(Boolean);
  if (!rows.length) return {};
  const header = rows[0].split(',').map((s) => s.trim());
  const nodeIdx = header.indexOf('node');
  const domainIdx = header.indexOf('domain');
  const avgCfIdx = header.indexOf('avg_cf');
  const cvIdx = header.indexOf('cv');
  const roleIdx = header.indexOf('role_plot') >= 0 ? header.indexOf('role_plot') : header.indexOf('label');
  const out: Record<number, BackboneMetric> = {};

  for (const row of rows.slice(1)) {
    const cols = row.split(',').map((s) => s.trim());
    const node = Number(cols[nodeIdx]);
    const avgCF = Number(cols[avgCfIdx]);
    const cv = Number(cols[cvIdx]);
    if (!Number.isFinite(node) || !Number.isFinite(avgCF) || !Number.isFinite(cv)) continue;
    out[node] = {
      domain: cols[domainIdx] ?? '',
      avgCF,
      cv,
      role: cols[roleIdx] ?? ''
    };
  }
  return out;
}

const modulesDir = path.join(process.cwd(), 'public', 'modules');
const reportPath = path.join(modulesDir, 'module_analysis_report.txt');
const reportModules = fs.existsSync(reportPath) ? parseModuleReport(fs.readFileSync(reportPath, 'utf8')) : {};
const csvFiles = fs.existsSync(modulesDir) ? fs.readdirSync(modulesDir).filter((f) => f.endsWith('.csv')) : [];

const edgesByPhase: Record<string, { source: string; target: string; weight: number }[]> = {};
for (const file of csvFiles) {
  const phaseChunk = file.replace(/^phase_/, '').replace(/_integrated_chord_diagram\.csv$/, '').replace(/_/g, ' ');
  const phaseId = phaseIdFromText(phaseChunk);
  if (!phaseId) continue;
  const raw = fs.readFileSync(path.join(modulesDir, file), 'utf8');
  edgesByPhase[phaseId] = parsePhaseCsv(raw);
}

const phaseModuleGraphs: PhaseGraph[] = phaseOrder.map((phaseId) => {
  const edges = edgesByPhase[phaseId] ?? [];
  const reportEntries = (reportModules[phaseId] ?? []).map((m) => ({ ...m }));
  let modules = reportEntries;

  if (!modules.length) {
    const labels = Array.from(new Set(edges.flatMap((e) => [e.source, e.target]))).sort();
    modules = labels.map((label) => ({ id: label, label, nodeCount: 0, nodes: [] }));
  } else {
    const edgeLabels = Array.from(new Set(edges.flatMap((e) => [e.source, e.target])));
    const idCount: Record<string, number> = {};
    modules.forEach((m) => { idCount[m.id] = (idCount[m.id] ?? 0) + 1; });
    const duplicateIndices = modules
      .map((m, idx) => ({ id: m.id, idx, nodeCount: m.nodeCount }))
      .filter((x) => idCount[x.id] > 1)
      .sort((a, b) => b.nodeCount - a.nodeCount)
      .map((x) => x.idx);
    const missingLabels = edgeLabels.filter((label) => !modules.some((m) => m.id === label));

    duplicateIndices.forEach((moduleIdx, i) => {
      if (!missingLabels[i]) return;
      modules[moduleIdx].id = missingLabels[i];
      modules[moduleIdx].label = missingLabels[i];
    });

    const afterFixMissing = edgeLabels.filter((label) => !modules.some((m) => m.id === label));
    afterFixMissing.forEach((label) => {
      modules.push({ id: label, label, nodeCount: 0, nodes: [] });
    });
  }

  return {
    phaseId,
    moduleCount: modules.length,
    modules,
    edges
  };
});

const phaseMetaList = phaseOrder.map((id) => phaseMeta[id]);
const manuscriptPdfUrl = `${normalizedBaseUrl}pdfs/main.pdf`;
const supplementaryPdfUrl = `${normalizedBaseUrl}pdfs/supplement.pdf`;
const analysisRepoUrl = 'https://github.com/realfty/covid-mcn';
const siteRepoUrl = 'https://github.com/zxzok/covid-mcn-site';
const summaryCoreFigureUrl = `${normalizedBaseUrl}figs/Early%20phase%20vs%20Post-Omicron.svg`;
const backboneFigureUrl = `${normalizedBaseUrl}figs/backbone.svg`;
const macroContextRightFigureUrl = `${normalizedBaseUrl}figs/marco%20policy.svg`;
const methodsPipelinePngUrl = `${normalizedBaseUrl}figs/fig1-600dpi.png`;
const robustnessFigureUrl = `${normalizedBaseUrl}figs/robustness.svg`;
const domainColorMap: Record<string, string> = {
  STR: '#CC79A7',
  EMO: '#E69F00',
  CSF: '#56B4E9',
  SPF: '#009E73',
  PHY: '#D55E00'
};
const backboneNodeDefs = [
  { id: 6, name: 'Self Control & Impulsivity', domain: 'EMO' },
  { id: 13, name: 'Speech & Language', domain: 'CSF' },
  { id: 16, name: 'Decision-making & Risk-taking', domain: 'EMO' },
  { id: 25, name: 'Outlook & Optimism', domain: 'SPF' },
  { id: 26, name: 'Selective Attention', domain: 'CSF' },
  { id: 28, name: 'Fear & Anxiety', domain: 'STR' },
  { id: 35, name: 'Nightmares', domain: 'STR' },
  { id: 38, name: 'Suicidal Thoughts or Intentions', domain: 'STR' },
  { id: 39, name: 'Experience of Pain', domain: 'STR' }
];
const backboneMetricPath = path.join(process.cwd(), 'public', 'acf-cv', 'backbone_table_main.csv');
const backboneMetricMap = fs.existsSync(backboneMetricPath)
  ? parseBackboneMetricCsv(fs.readFileSync(backboneMetricPath, 'utf8'))
  : {};
const backboneInterpretationMap: Record<number, { why: string; interpretation: string }> = {
  6: {
    why: 'Consistently high control frequency indicates emotion-regulation leverage remains central.',
    interpretation: 'Self-control/impulsivity likely indexes immediate regulation pressure under prolonged stress.'
  },
  13: {
    why: 'Cognitive-social language function remains inside the high-impact controller set.',
    interpretation: 'Speech/language may reflect communication and executive coordination burden across phases.'
  },
  16: {
    why: 'Decision risk control is repeatedly retained among backbone candidates.',
    interpretation: 'Risk-taking governance can mediate how stress translates into behavior-level outcomes.'
  },
  25: {
    why: 'A stable SPF anchor suggests adaptation-related regulation is not peripheral.',
    interpretation: 'Outlook/optimism may provide cross-domain stabilization rather than isolated resilience.'
  },
  26: {
    why: 'Selective attention stays influential despite broader control redistribution.',
    interpretation: 'Attentional gating can shape which symptom circuits become active downstream.'
  },
  28: {
    why: 'Fear/anxiety remains in the persistent core even when phase context changes.',
    interpretation: 'This supports continuity of stress-linked control within a conserved scaffold.'
  },
  35: {
    why: 'Nightmare-related disturbance is retained among key controllers in the STR cluster.',
    interpretation: 'Sleep-disruption features may act as chronic stress amplifiers rather than transient effects.'
  },
  38: {
    why: 'High-risk distress marker remains mapped to the backbone set.',
    interpretation: 'Suicidal ideation signals may represent concentrated burden points requiring targeted attention.'
  },
  39: {
    why: 'Experience of pain is persistently represented among high-control STR nodes.',
    interpretation: 'Pain likely captures embodied stress load bridging psychological and physiological channels.'
  }
};
const backboneNodesForView = backboneNodeDefs.map((node) => {
  const metric = backboneMetricMap[node.id];
  return {
    ...node,
    avgCF: metric ? metric.avgCF : null,
    cv: metric ? metric.cv : null,
    why: backboneInterpretationMap[node.id]?.why ?? 'Persistent inclusion in the backbone set across the cross-phase control landscape.',
    interpretation: backboneInterpretationMap[node.id]?.interpretation ?? 'Supports core-symptom continuity within the manuscript interpretation framework.'
  };
});
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Module Control in Youth Symptom Networks — Paper Website</title>
  <meta name="description" content="Paper website for the manuscript: Module control in youth symptom networks across COVID-19" />
  <style is:inline>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500&display=swap');

    :root {
      --bg: #f8fbff;
      --card: #ffffff;
      --accent: #1e40af;
      --text: #0f172a;
      --muted: #1f2937;
      --border: #c8d8ee;
      --footer-bg: #f0f6ff;
      --str: #CC79A7;
      --emo: #E69F00;
      --csf: #56B4E9;
      --spf: #009E73;
      --phy: #D55E00;
      --radius: 10px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'IBM Plex Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-weight: 400;
      line-height: 1.72;
      font-size: 17px;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 { font-family: 'DM Serif Display', serif; font-weight: 400; line-height: 1.2; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; display: block; }
    button { font-family: inherit; cursor: pointer; }

    .wrap { width: min(1080px, calc(100vw - 48px)); margin: 0 auto; }
    .sec-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sec-title { font-size: clamp(1.6rem, 3.2vw, 2.4rem); margin-bottom: 12px; }
    .sec-sub { color: var(--muted); font-size: clamp(0.98rem, 1.08vw, 1.1rem); max-width: 60ch; line-height: 1.72; }

    /* ── Nav ── */
    .site-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.9); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid var(--border); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; }
    .nav-brand { display: flex; align-items: center; gap: 10px; color: var(--text); text-decoration: none; font-weight: 500; font-size: 0.88rem; }
    .nav-mark { width: 30px; height: 30px; border-radius: 7px; background: var(--accent); display: grid; place-items: center; font-weight: 500; font-size: 0.68rem; color: #fff; flex-shrink: 0; }
    .nav-links { display: flex; gap: 4px; }
    .nav-link { padding: 6px 14px; border-radius: 6px; color: var(--muted); font-size: 0.88rem; font-weight: 400; transition: all 0.2s; text-decoration: none; }
    .nav-link:hover, .nav-link.active { color: var(--text); background: rgba(29,78,216,0.09); text-decoration: none; }
    .nav-link.active { color: var(--accent); }

    /* ── Hero ── */
    .hero { min-height: 88vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 72px 24px 28px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -40%; left: -20%; width: 140%; height: 140%; background: radial-gradient(ellipse at 50% 30%, rgba(29,78,216,0.08) 0%, transparent 60%); pointer-events: none; }
    .hero-overline { font-size: 0.76rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.22em; color: var(--accent); margin-bottom: 22px; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
    .hero-title { font-size: clamp(2.8rem, 7vw, 5rem); line-height: 1.06; margin-bottom: 22px; opacity: 0; animation: fadeUp 0.8s 0.4s forwards; }
    .hero-title .amber { color: var(--accent); }
    .hero-sub { font-size: clamp(1rem, 1.2vw, 1.12rem); color: var(--muted); max-width: 56ch; margin-bottom: 26px; line-height: 1.72; opacity: 0; animation: fadeUp 0.8s 0.6s forwards; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 28px; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
    .hero-cta { display: inline-flex; align-items: center; justify-content: center; padding: 9px 16px; border: 1px solid var(--border); border-radius: 999px; color: var(--text); font-size: 0.84rem; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; background: rgba(255,255,255,0.72); transition: border-color 0.2s, transform 0.2s, background 0.2s; }
    .hero-cta:hover { text-decoration: none; border-color: var(--accent); background: #fff; transform: translateY(-1px); }
    .hero-cta-icon { width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center; margin-right: 8px; color: var(--accent); flex-shrink: 0; }
    .hero-cta-icon svg { width: 100%; height: 100%; display: block; }
    .hero-stats { display: flex; gap: clamp(24px, 5vw, 56px); margin-bottom: 30px; opacity: 0; animation: fadeUp 0.8s 0.8s forwards; }
    .h-stat { text-align: center; }
    .h-stat-num { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1.1; }
    .h-stat-label { font-size: 0.78rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-top: 6px; }
    .hero-domains { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 36px; opacity: 0; animation: fadeUp 0.8s 1.0s forwards; }
    .hdot { display: flex; align-items: center; gap: 6px; font-size: 0.84rem; color: var(--muted); }
    .hdot i { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .scroll-arrow { position: absolute; bottom: 22px; left: 50%; transform: translateX(-50%); opacity: 0; animation: fadeUp 0.8s 1.2s forwards; display: inline-flex; flex-direction: column; align-items: center; gap: 6px; color: var(--muted); text-decoration: none; }
    .scroll-arrow small { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--muted); opacity: 0.9; }
    .scroll-arrow i { display: block; width: 1px; height: 10px; background: var(--border); }
    .scroll-arrow span { display: block; width: 14px; height: 14px; border-right: 2px solid var(--muted); border-bottom: 2px solid var(--muted); transform: rotate(45deg); animation: bounce 1.8s infinite; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%,100% { transform: rotate(45deg) translateY(0); } 50% { transform: rotate(45deg) translateY(8px); } }

    /* ── Shared figures ── */
    .fig-wrap { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); background: var(--card); }
    .fig-wrap img { width: 100%; display: block; }
    .fig-cap { padding: 10px 14px; font-size: 0.84rem; color: var(--muted); border-top: 1px solid var(--border); }
    /* SVG figures need light bg */
    .svg-fig { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); background: #f8f9fb; padding: 8px; }
    .svg-fig img { width: 100%; display: block; border-radius: 6px; }
    .svg-fig .fig-cap { background: var(--card); border-top: 1px solid var(--border); margin: 8px -8px -8px; padding: 10px 14px; border-radius: 0; }

    /* ── Cards ── */
    .s-card { background: var(--card); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); position: relative; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; }
    .s-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .s-card-num { position: absolute; top: -8px; right: 12px; font-family: 'DM Serif Display', serif; font-size: 4rem; color: var(--accent); opacity: 0.07; line-height: 1; pointer-events: none; }
    .s-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 8px; }
    .s-card p { font-size: clamp(0.86rem, 0.92vw, 0.94rem); color: var(--muted); line-height: 1.65; }

    /* ── Grid layouts ── */
    .g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .g3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .g12 { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(16px, 3vw, 32px); align-items: start; }

    /* ── Sections ── */
    .sec { padding: clamp(60px, 8vw, 100px) 0; }

    /* ── Phase timeline ── */
    .timeline { display: flex; align-items: center; justify-content: space-between; position: relative; margin: 36px 0 32px; padding: 0 20px; }
    .timeline::before { content: ''; position: absolute; top: 50%; left: 20px; right: 20px; height: 2px; background: var(--border); transform: translateY(-50%); }
    .tl-node { position: relative; z-index: 1; background: none; border: 2px solid var(--muted); width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s; color: var(--muted); font-size: 0.72rem; font-weight: 500; }
    .tl-node.active { background: var(--accent); border-color: var(--accent); color: #fff; box-shadow: 0 0 20px rgba(29,78,216,0.25); }
    .tl-node:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
    .tl-label { position: absolute; top: calc(100% + 8px); white-space: nowrap; font-size: 0.72rem; color: var(--muted); transition: color 0.3s; }
    .tl-node.active .tl-label { color: var(--accent); font-weight: 500; }
    .tl-date { position: absolute; bottom: calc(100% + 6px); white-space: nowrap; font-size: 0.64rem; color: var(--muted); opacity: 0.6; }

    .info-panel { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 28px); }
    .pill-tag { display: inline-block; font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); padding: 4px 10px; border: 1px solid rgba(29,78,216,0.25); border-radius: 999px; margin-bottom: 12px; }
    .p-badge { font-size: 0.74rem; padding: 4px 10px; border-radius: 999px; background: rgba(29,78,216,0.08); border: 1px solid rgba(29,78,216,0.15); color: var(--muted); display: inline-block; margin-right: 6px; margin-bottom: 8px; }
    .p-badge strong { color: var(--text); font-weight: 500; }
    .selected-module { margin: 0 0 14px; font-size: 0.84rem; color: var(--muted); }
    .selected-module strong { color: var(--accent); font-weight: 500; }
    .sc-box { background: #f7fbff; border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; }
    .sc-box h5 { font-size: 0.76rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .sc-box p { font-size: 0.86rem; color: var(--muted); line-height: 1.55; }
    .phase-fig-transition { transition: opacity 0.4s ease; }
    .phase-fig-transition.fading { opacity: 0.3; }
    .svg-box { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); background: var(--card); }
    .phase-legend { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; }
    .phase-legend h5 { font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-bottom: 10px; }
    .legend-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px 12px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--muted); }
    .legend-swatch { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .phase-note { margin-top: 10px; font-size: 0.78rem; color: var(--muted); line-height: 1.6; }

    /* ── Backbone ── */
    .bb-list-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 28px); }
    .bb-list-card h4 { font-size: clamp(1.05rem, 1.2vw, 1.2rem); margin-bottom: 10px; }
    .bb-list-note { font-size: 0.82rem; color: var(--muted); margin-bottom: 12px; }
    .bb-node-list { list-style: none; display: grid; gap: 8px; }
    .bb-node-btn { width: 100%; border: 1px solid var(--border); border-radius: 8px; background: #f8fbff; padding: 9px 12px; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 12px; text-align: left; transition: border-color 0.2s, box-shadow 0.2s, background 0.2s; }
    .bb-node-btn:hover { border-color: rgba(29, 78, 216, 0.45); background: #ffffff; }
    .bb-node-btn.active { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(29, 78, 216, 0.12); background: #ffffff; }
    .bb-node-main { font-size: 0.9rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bb-node-id { font-weight: 500; color: var(--accent); margin-right: 6px; }
    .bb-node-meta { font-size: 0.76rem; color: var(--muted); display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; }
    .bb-domain-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .bb-detail { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 28px); min-height: 180px; }
    .bb-tag { display: inline-block; font-size: 0.7rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 999px; border: 1px solid var(--border); color: var(--muted); margin-right: 6px; margin-bottom: 12px; }
    .bb-detail h4 { font-size: clamp(1.05rem, 1.2vw, 1.2rem); margin-bottom: 12px; }
    .bb-detail p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; margin-bottom: 10px; }
    .bb-detail p strong { color: var(--text); font-weight: 500; }
    .bb-metrics { font-size: 0.82rem; color: var(--muted); margin-bottom: 10px; }
    .bb-right-col { display: flex; flex-direction: column; gap: 12px; }
    .bb-fig-compact { max-width: 88%; margin: 0 auto; }
    .macro-subhead { margin-top: 22px; margin-bottom: 10px; }
    .macro-subhead h4 { font-size: clamp(1.02rem, 1.2vw, 1.16rem); margin-bottom: 8px; }
    .macro-subhead p { font-size: 0.86rem; color: var(--muted); line-height: 1.62; max-width: 90ch; }
    .macro-single-fig { max-width: 960px; margin: 0 auto; }
    .macro-disclaimer { margin-top: 10px; font-size: 0.72rem; color: #64748b; line-height: 1.55; }
    .macro-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(16px, 2vw, 22px); display: flex; gap: 12px; transition: transform 0.3s, box-shadow 0.3s; }
    .macro-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .macro-icon { width: 4px; border-radius: 2px; flex-shrink: 0; }
    .macro-card h5 { font-size: 0.88rem; font-weight: 500; color: var(--text); margin-bottom: 6px; }
    .macro-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.55; }

    /* ── Methods ── */
    .pipeline-horizontal-wrap { overflow-x: auto; padding-bottom: 4px; }
    .pipeline-horizontal { display: flex; gap: 12px; min-width: 1120px; align-items: stretch; }
    .pipe-h-item { flex: 1 0 214px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card); padding: 14px 14px 12px; position: relative; }
    .pipe-h-item:not(:last-child)::after { content: '→'; position: absolute; right: -10px; top: 22px; font-size: 18px; color: #94a3b8; z-index: 2; }
    .pipe-h-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .pipe-num { width: 26px; height: 26px; border-radius: 50%; background: var(--accent); display: grid; place-items: center; font-size: 0.68rem; font-weight: 500; color: var(--bg); flex-shrink: 0; }
    .pipe-h-item h5 { font-size: 0.86rem; font-weight: 500; color: var(--text); margin: 0; line-height: 1.35; }
    .pipe-h-item p { font-size: 0.8rem; color: var(--muted); line-height: 1.52; margin: 0; }
    .methods-figure-shell { width: min(1220px, calc(100vw - 64px)); margin: 30px auto 0; }
    .methods-figure-card { border: 1px solid var(--border); border-radius: var(--radius); background: var(--card); overflow: hidden; }
    .methods-png-view { width: 100%; height: auto; display: block; background: #fff; }
    .methods-figure-actions { padding: 12px 14px 14px; border-top: 1px solid var(--border); background: #fbfdff; }
    .methods-figure-btn { display: inline-flex; align-items: center; justify-content: center; padding: 9px 14px; border-radius: 999px; border: 1px solid var(--border); color: var(--text); font-size: 0.8rem; font-weight: 500; text-decoration: none; background: #fff; transition: border-color 0.2s, transform 0.2s; }
    .methods-figure-btn:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-1px); }

    /* ── Robustness ── */
    .rob-layout { display: grid; grid-template-columns: minmax(0, 1.28fr) minmax(280px, 0.72fr); gap: clamp(16px, 2.5vw, 24px); align-items: start; }
    .rob-figure img { background: #fff; }
    .rob-actions { padding: 12px 14px 14px; border-top: 1px solid var(--border); background: #fbfdff; }
    .rob-supp-btn { display: inline-flex; align-items: center; justify-content: center; padding: 8px 14px; border-radius: 999px; border: 1px solid var(--border); color: var(--text); font-size: 0.78rem; font-weight: 500; text-decoration: none; background: #fff; transition: border-color 0.2s, transform 0.2s; }
    .rob-supp-btn:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-1px); }
    .rob-right { display: grid; gap: 12px; }
    .rob-note-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(14px, 1.8vw, 18px); }
    .rob-note-card h5 { font-size: 0.86rem; font-weight: 500; color: var(--text); margin-bottom: 6px; line-height: 1.4; }
    .rob-note-card p { font-size: 0.83rem; color: var(--muted); line-height: 1.6; margin: 0; }

    /* ── Significance ── */
    .sig-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(20px, 2.5vw, 28px); border-top: 3px solid var(--accent); transition: transform 0.3s, box-shadow 0.3s; }
    .sig-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); }
    .sig-card:nth-child(1) { border-top-color: var(--spf); }
    .sig-card:nth-child(2) { border-top-color: var(--csf); }
    .sig-card:nth-child(3) { border-top-color: var(--emo); }
    .sig-cat { font-size: 0.68rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent); margin-bottom: 12px; }
    .sig-card:nth-child(1) .sig-cat { color: var(--spf); }
    .sig-card:nth-child(2) .sig-cat { color: var(--csf); }
    .sig-card:nth-child(3) .sig-cat { color: var(--emo); }
    .sig-card h4 { font-size: clamp(1rem, 1.1vw, 1.12rem); margin-bottom: 10px; }
    .sig-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }

    /* ── Quick Guide ── */
    .qg-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(18px, 2.5vw, 28px); }
    .qg-step { background: #f7fbff; border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; }
    .qg-step h4 { font-size: 0.9rem; margin-bottom: 6px; }
    .qg-step p { font-size: 0.86rem; color: var(--muted); margin: 0; line-height: 1.6; }
    .qg-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
    .qg-link { display: inline-flex; align-items: center; gap: 8px; padding: 10px 14px; border-radius: 999px; border: 1px solid var(--border); color: var(--text); font-size: 0.82rem; font-weight: 500; text-decoration: none; transition: all 0.25s; }
    .qg-link:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-1px); }

    /* ── Accordion ── */
    .accord-item { border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 8px; overflow: hidden; background: var(--card); }
    .accord-trigger { width: 100%; background: none; border: none; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; color: var(--text); font-size: 0.92rem; font-weight: 500; text-align: left; transition: color 0.2s; }
    .accord-trigger:hover { color: var(--accent); }
    .accord-icon { font-size: 1.2rem; color: var(--muted); transition: transform 0.3s; font-style: normal; }
    .accord-item.open .accord-icon { transform: rotate(45deg); }
    .accord-body { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
    .accord-item.open .accord-body { max-height: 300px; }
    .accord-content { padding: 0 20px 18px; font-size: 0.88rem; color: var(--muted); line-height: 1.6; }

    /* ── Footer ── */
    .site-footer { background: var(--footer-bg); padding: clamp(48px, 6vw, 80px) 0 40px; border-top: 1px solid var(--border); }
    .footer-label { font-size: 0.72rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.18em; color: var(--accent); margin-bottom: 20px; }
    .gl-entry { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 16px 18px; }
